{
    "module": "N/format",
    "description": "Use the format module to parse formatted data into strings and to convert strings into a specified format. The format module formats data according to personal preferences set on the Set Preferences page, accessible from Home > Set Preferences.",
    "supportedIn": ["client", "server"],
    "methods": [
        {
            "name": "format",
            "description": "Takes a raw value and returns a formatted value. This method is overloaded when you format a datetime or datetimetz value.",
            "supportedIn": ["client", "server"],
            "params": [
                {
                    "name": "options.value",
                    "type": "Date | string | number",
                    "description": "The input data to format.",
                    "optional": false
                },
                {
                    "name": "options.type",
                    "type": "string",
                    "description": "The field type (for example, DATE, CURRENCY, INTEGER). Use the format.Type enum to set this value.",
                    "optional": false
                },
                {
                    "name": "options.timezone",
                    "type": "format.Timezone | number",
                    "description": "The time zone specified for the returned string. Set using the format.Timezone enum or key. If not specified, the time zone is set based on user preference. Applies to datetime and datetimetz values only.",
                    "optional": true
                }
            ],
            "returns": "string | Date"
        },
        {
            "name": "parse",
            "description": "Takes a formatted value and returns a raw value. This method is overloaded when you parse a datetime or datetimetz value.",
            "supportedIn": ["client", "server"],
            "params": [
                {
                    "name": "options.value",
                    "type": "string",
                    "description": "The formatted value to parse.",
                    "optional": false
                },
                {
                    "name": "options.type",
                    "type": "string",
                    "description": "The field type (for example, DATE, CURRENCY, INTEGER). Use the format.Type enum to set this value.",
                    "optional": false
                },
                {
                    "name": "options.timezone",
                    "type": "format.Timezone | number",
                    "description": "The time zone for parsing. Set using the format.Timezone enum or key. Applies to datetime and datetimetz values only.",
                    "optional": true
                }
            ],
            "returns": "Date | number | string"
        }
    ],
    "enums": [
        {
