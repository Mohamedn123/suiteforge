{
    "module": "N/file",
    "description": "Use the N/file module to work with files within NetSuite. You can use this module to upload files to the NetSuite File Cabinet, as well as send files as attachments without uploading them to the File Cabinet. You can also use this module to copy files in the File Cabinet, and you can use conflict resolution options to handle conflicts.",
    "supportedIn": ["server"],
    "methods": [
        {
            "name": "copy",
            "description": "Copies an existing file in the File Cabinet.",
            "params": [
                {
                    "name": "options.id",
                    "type": "number",
                    "description": "The internal ID of the file to copy."
                },
                {
                    "name": "options.folder",
                    "type": "number",
                    "description": "The internal ID of the folder to copy the file to."
                },
                {
                    "name": "options.conflictResolution",
                    "type": "string",
                    "description": "The conflict resolution value. Use file.NameConflictResolution enum. The default value is FAIL.",
                    "optional": true
                }
            ],
            "returns": "file.File",
            "returnType": "N/file#File"
        },
        {
            "name": "create",
            "description": "Creates a new file in the NetSuite File Cabinet. Content held in memory is limited to 10MB.",
            "params": [
                {
                    "name": "options.name",
                    "type": "string",
                    "description": "The file name and extension."
                },
                {
                    "name": "options.fileType",
                    "type": "string",
                    "description": "The file type. Use the file.Type enum to set the value."
                },
                {
                    "name": "options.contents",
                    "type": "string",
                    "description": "The file content. If the file type is binary (for example, PDF), the file content must be base64 encoded.",
                    "optional": true
                },
                {
                    "name": "options.description",
                    "type": "string",
                    "description": "The file description.",
                    "optional": true
                },
                {
                    "name": "options.encoding",
                    "type": "string",
                    "description": "The character encoding on a file. Use the file.Encoding enum to set the value.",
                    "optional": true
                },
                {
                    "name": "options.folder",
                    "type": "number",
                    "description": "The internal ID of the folder within the NetSuite File Cabinet.",
                    "optional": true
                },
                {
                    "name": "options.isInactive",
                    "type": "boolean",
                    "description": "The inactive status of a file. If set to true, the file is inactive. The default value is false.",
                    "optional": true
                },
                {
                    "name": "options.isOnline",
                    "type": "boolean",
                    "description": "The Available without Login status. If set to true, users can download the file outside of a current NetSuite login session. The default value is false.",
                    "optional": true
                }
            ],
            "returns": "file.File",
            "returnType": "N/file#File"
        },
        {
            "name": "delete",
            "description": "Deletes an existing file from the NetSuite File Cabinet.",
            "params": [
                {
                    "name": "options.id",
                    "type": "number",
                    "description": "The internal ID of the file to delete."
                }
            ],
            "returns": "void"
        },
        {
            "name": "load",
            "description": "Loads an existing file from the NetSuite File Cabinet. The file size limit for this method is 2GB.",
            "params": [
                {
                    "name": "options.id",
                    "type": "number | string",
                    "description": "The internal ID of the file (number or string), or the file path in the File Cabinet (e.g. 'Images/myImageFile.jpg'). Supports absolute and relative paths."
                }
            ],
            "returns": "file.File",
            "returnType": "N/file#File"
        }
    ],
