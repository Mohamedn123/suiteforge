            "name": "NameConflictResolution",
            "description": "Holds conflict resolution values that apply when copying a file. Use this enum to specify how to resolve conflicts when copying files.",
            "members": [
                {
                    "name": "FAIL",
                    "value": "FAIL",
                    "description": "Fail with an error if a conflict occurs."
                },
                {
                    "name": "OVERWRITE",
                    "value": "OVERWRITE",
                    "description": "Overwrite the existing file if a conflict occurs. Attributes and permissions of the overwritten file are preserved."
                },
                {
                    "name": "OVERWRITE_CONTENT_AND_ATTRIBUTES",
                    "value": "OVERWRITE_CONTENT_AND_ATTRIBUTES",
                    "description": "Overwrite the existing file if a conflict occurs. Attributes and permissions are also overwritten."
                },
                {
                    "name": "RENAME_TO_UNIQUE",
                    "value": "RENAME_TO_UNIQUE",
                    "description": "Add a numeric suffix to the name of the copied file if a conflict occurs."
