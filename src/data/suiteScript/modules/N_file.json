    "objectTypes": [
        {
            "name": "File",
            "description": "Encapsulates a file within NetSuite.",
            "methods": [
                {
                    "name": "appendLine",
                    "description": "Inserts a line to the end of a CSV or text file.",
                    "params": [
                        {
                            "name": "options.value",
                            "type": "string",
                            "description": "The line to append."
                        }
                    ],
                    "returns": "file.File",
                    "returnType": "N/file#File"
                },
                {
                    "name": "getContents",
                    "description": "Returns the content of a file in string format. Files loaded in memory are limited to 10MB.",
                    "params": [],
                    "returns": "string"
                },
                {
                    "name": "getReader",
                    "description": "Returns a reader object for performing special read operations.",
                    "params": [],
                    "returns": "file.Reader",
                    "returnType": "N/file#Reader"
                },
                {
                    "name": "getSegments",
                    "description": "Returns an iterator of segments delimited by the specified separator. The separator is included in each segment.",
                    "params": [
                        {
                            "name": "options.separator",
                            "type": "string",
                            "description": "The separator to use to divide the segments."
                        }
                    ],
                    "returns": "Iterator"
                },
                {
                    "name": "lines.iterator",
                    "description": "Returns an iterator that enables you to iterate over each line in the file. Use the each method on the returned iterator to process each line.",
                    "params": [],
                    "returns": "Iterator"
                },
                {
                    "name": "resetStream",
                    "description": "Resets the file stream to its previous state.",
                    "params": [],
                    "returns": "void"
                },
                {
                    "name": "save",
                    "description": "Saves a new or updated file to the File Cabinet. Returns the internal ID of the saved file.",
                    "params": [],
                    "returns": "number"
                }
            ],
            "properties": [
                {
                    "name": "description",
                    "type": "string",
                    "description": "Description of a file."
                },
                {
                    "name": "encoding",
                    "type": "string",
                    "description": "Character encoding on a file. Use the file.Encoding enum to set the value."
                },
                {
                    "name": "fileType",
                    "type": "string",
                    "description": "File type of a file. Use the file.Type enum. This property is read-only after the file is created."
                },
                {
                    "name": "folder",
                    "type": "number",
                    "description": "Internal ID of the folder that houses a file within the NetSuite File Cabinet."
                },
                {
                    "name": "id",
                    "type": "number",
                    "readOnly": true,
                    "description": "Internal ID of a file in the NetSuite File Cabinet."
                },
                {
                    "name": "isInactive",
                    "type": "boolean",
                    "description": "Inactive status of a file. If set to true, the file is inactive."
                },
                {
                    "name": "isOnline",
                    "type": "boolean",
                    "description": "Available without Login status. If set to true, users can download the file outside of a current NetSuite login session."
                },
                {
                    "name": "isText",
                    "type": "boolean",
                    "readOnly": true,
                    "description": "Indicates whether a file type is text-based."
                },
                {
                    "name": "name",
                    "type": "string",
                    "description": "Name of a file."
                },
                {
                    "name": "path",
                    "type": "string",
                    "readOnly": true,
                    "description": "Relative path to a file in the NetSuite File Cabinet."
                },
                {
                    "name": "size",
                    "type": "number",
                    "readOnly": true,
                    "description": "Size of a file in bytes."
                },
                {
                    "name": "url",
                    "type": "string",
                    "readOnly": true,
                    "description": "URL of a file."
                }
            ]
        },
        {
            "name": "Reader",
            "description": "Encapsulates a reader that you can use to perform special read operations.",
            "methods": [
                {
                    "name": "readChars",
                    "description": "Returns the next specified number of characters from the current position.",
                    "params": [
                        {
                            "name": "options.number",
                            "type": "number",
                            "description": "The number of characters to read."
                        }
                    ],
                    "returns": "string"
                },
                {
                    "name": "readUntil",
                    "description": "Returns a string from the current position to the next occurrence of the specified tag.",
                    "params": [
                        {
                            "name": "options.tag",
                            "type": "string",
                            "description": "The tag to read until."
                        }
                    ],
                    "returns": "string"
                }
            ],
            "properties": []
        }
    ]
}
