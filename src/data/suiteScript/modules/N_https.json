        {
            "name": "ServerRequest",
            "description": "Encapsulates the HTTPS request information sent to an HTTPS server. For example, a request received by a Suitelet or RESTlet.",
            "methods": [
                {
                    "name": "getHeader",
                    "description": "Returns the value of a request header.",
                    "params": [
                        { "name": "options", "type": "Object", "description": "Options" },
                        { "name": "options.name", "type": "string", "description": "The header name." }
                    ],
                    "returns": "string"
                },
