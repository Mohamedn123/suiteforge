                { "name": "options.body", "type": "string|Object", "description": "The POST data." },
                { "name": "options.headers", "type": "Object", "description": "Request headers.", "optional": true }
            ],
            "returns": "Promise<https.ClientResponse>"
        },
        {
            "name": "put",
            "description": "Sends an HTTPS PUT request and returns the response.",
