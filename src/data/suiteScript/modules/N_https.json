        },
        {
            "name": "put.promise",
            "description": "Sends an HTTPS PUT request asynchronously and returns the response.",
            "params": [
                { "name": "options", "type": "Object", "description": "Request options" },
                { "name": "options.url", "type": "string", "description": "The HTTPS URL being requested." },
                { "name": "options.body", "type": "string|Object", "description": "The PUT data." },
                { "name": "options.headers", "type": "Object", "description": "Request headers.", "optional": true }
            ],
            "returns": "Promise<https.ClientResponse>"
        },
        {
            "name": "delete",
            "description": "Sends an HTTPS DELETE request and returns the response.",
            "params": [
                { "name": "options", "type": "Object", "description": "Request options" },
                { "name": "options.url", "type": "string", "description": "The HTTPS URL being requested." },
                { "name": "options.headers", "type": "Object", "description": "Request headers.", "optional": true }
            ],
            "returns": "https.ClientResponse",
            "returnType": "N/https#ClientResponse"
        },
        {
            "name": "delete.promise",
            "description": "Sends an HTTPS DELETE request asynchronously and returns the response.",
            "params": [
                { "name": "options", "type": "Object", "description": "Request options" },
                { "name": "options.url", "type": "string", "description": "The HTTPS URL being requested." },
                { "name": "options.headers", "type": "Object", "description": "Request headers.", "optional": true }
            ],
            "returns": "Promise<https.ClientResponse>"
        },
        {
            "name": "request",
            "description": "Sends an HTTPS request and returns the response.",
            "params": [
                { "name": "options", "type": "Object", "description": "Request options" },
                { "name": "options.method", "type": "string", "description": "The HTTPS method. Use https.Method enum to set the value." },
                { "name": "options.url", "type": "string", "description": "The HTTPS URL being requested." },
                { "name": "options.body", "type": "string|Object", "description": "The request body.", "optional": true },
                { "name": "options.headers", "type": "Object", "description": "Request headers.", "optional": true }
            ],
            "returns": "https.ClientResponse",
            "returnType": "N/https#ClientResponse"
        },
        {
            "name": "request.promise",
            "description": "Sends an HTTPS request asynchronously and returns the response.",
            "params": [
                { "name": "options", "type": "Object", "description": "Request options" },
                { "name": "options.method", "type": "string", "description": "The HTTPS method. Use https.Method enum to set the value." },
                { "name": "options.url", "type": "string", "description": "The HTTPS URL being requested." },
                { "name": "options.body", "type": "string|Object", "description": "The request body.", "optional": true },
                { "name": "options.headers", "type": "Object", "description": "Request headers.", "optional": true }
            ],
            "returns": "Promise<https.ClientResponse>"
        },
        {
            "name": "createSecretKey",
            "description": "Creates and returns a crypto.SecretKey object. This method can take a GUID or a secret.",
            "params": [
                { "name": "options", "type": "Object", "description": "Options" },
                { "name": "options.guid", "type": "string", "description": "A GUID used to generate a secret key. Required if secret is not specified.", "optional": true },
                { "name": "options.secret", "type": "string", "description": "The script ID of the secret used for authentication. Required if guid is not specified.", "optional": true },
                { "name": "options.encoding", "type": "string", "description": "The encoding for the SecretKey. Use https.Encoding enum to set the value.", "optional": true }
            ],
            "returns": "crypto.SecretKey",
            "returnType": "N/crypto#SecretKey",
            "supportedIn": ["server"]
        },
        {
            "name": "createSecureString",
            "description": "Creates and returns an https.SecureString object.",
            "params": [
                { "name": "options", "type": "Object", "description": "Options" },
                { "name": "options.input", "type": "string", "description": "The string to convert to a SecureString." },
                { "name": "options.inputEncoding", "type": "string", "description": "The encoding of the input string. Use https.Encoding enum. Default is UTF_8.", "optional": true }
            ],
            "returns": "https.SecureString",
            "returnType": "N/https#SecureString",
            "supportedIn": ["server"]
        },
        {
            "name": "requestRestlet",
            "description": "Sends an HTTPS request to a RESTlet and returns the response. Authentication headers are automatically added.",
            "params": [
                { "name": "options", "type": "Object", "description": "Options" },
                { "name": "options.body", "type": "string|Object", "description": "The PUT/POST data. Required if method is POST or PUT.", "optional": true },
                { "name": "options.headers", "type": "Object", "description": "The HTTPS headers.", "optional": true },
                { "name": "options.method", "type": "string", "description": "The HTTPS method (DELETE, GET, HEAD, POST, PUT). Default is GET or POST based on body.", "optional": true },
                { "name": "options.scriptId", "type": "string|number", "description": "The internal ID or script ID of the script record." },
                { "name": "options.deploymentId", "type": "string", "description": "The script ID of the script deployment record." },
                { "name": "options.urlParams", "type": "Object", "description": "Parameters to be appended to the target URL as a query string.", "optional": true }
            ],
            "returns": "https.ClientResponse",
            "returnType": "N/https#ClientResponse",
            "supportedIn": ["server"]
        },
        {
            "name": "requestRestlet.promise",
            "description": "Sends an HTTPS request to a RESTlet asynchronously and returns the response.",
            "params": [
                { "name": "options", "type": "Object", "description": "Options" },
                { "name": "options.body", "type": "string|Object", "description": "The PUT/POST data.", "optional": true },
                { "name": "options.headers", "type": "Object", "description": "The HTTPS headers.", "optional": true },
                { "name": "options.method", "type": "string", "description": "The HTTPS method.", "optional": true },
                { "name": "options.scriptId", "type": "string|number", "description": "The internal ID or script ID of the script record." },
                { "name": "options.deploymentId", "type": "string", "description": "The script ID of the script deployment record." },
                { "name": "options.urlParams", "type": "Object", "description": "Parameters to be appended to the target URL.", "optional": true }
            ],
            "returns": "Promise<https.ClientResponse>"
        },
        {
            "name": "requestSuitelet",
            "description": "Sends an HTTPS request to a Suitelet and returns the response.",
            "params": [
                { "name": "options", "type": "Object", "description": "Options" },
                { "name": "options.scriptId", "type": "string", "description": "The script ID of the script record." },
                { "name": "options.deploymentId", "type": "string", "description": "The script ID of the script deployment record." },
                { "name": "options.body", "type": "string|Object", "description": "The body content to send. Only PUT, POST, and PATCH methods support this.", "optional": true },
                { "name": "options.headers", "type": "Object", "description": "The HTTPS headers.", "optional": true },
                { "name": "options.method", "type": "string", "description": "The HTTPS request method. Default is GET or POST based on body.", "optional": true },
                { "name": "options.urlParams", "type": "Object", "description": "Parameters to be appended to the target URL as a query string.", "optional": true }
            ],
            "returns": "https.ClientResponse",
            "returnType": "N/https#ClientResponse"
        },
        {
            "name": "requestSuitelet.promise",
            "description": "Sends an HTTPS request asynchronously to a Suitelet and returns the response.",
            "params": [
                { "name": "options", "type": "Object", "description": "Options" },
                { "name": "options.scriptId", "type": "string", "description": "The script ID of the script record." },
                { "name": "options.deploymentId", "type": "string", "description": "The script ID of the script deployment record." },
                { "name": "options.body", "type": "string|Object", "description": "The body content to send.", "optional": true },
                { "name": "options.headers", "type": "Object", "description": "The HTTPS headers.", "optional": true },
                { "name": "options.method", "type": "string", "description": "The HTTPS request method.", "optional": true },
                { "name": "options.urlParams", "type": "Object", "description": "Parameters to be appended to the target URL.", "optional": true }
            ],
            "returns": "Promise<https.ClientResponse>"
        },
        {
            "name": "requestSuiteTalkRest",
            "description": "Sends an HTTPS request to a SuiteTalk REST endpoint and returns the response. Authentication headers are automatically added.",
            "params": [
                { "name": "options", "type": "Object", "description": "Options" },
                { "name": "options.body", "type": "string|Object", "description": "The PUT/POST data. Required if method is POST or PUT.", "optional": true },
                { "name": "options.url", "type": "string", "description": "The URL of a SuiteTalk REST endpoint." },
                { "name": "options.headers", "type": "Object", "description": "The HTTPS headers.", "optional": true },
                { "name": "options.method", "type": "string", "description": "The HTTPS method (DELETE, GET, HEAD, POST, PUT). Default is GET or POST based on body.", "optional": true }
            ],
            "returns": "https.ClientResponse",
            "returnType": "N/https#ClientResponse",
            "supportedIn": ["server"]
        }
    ],
