{
    "module": "N/https",
    "description": "Use the N/https module to manage content sent to a third party using HTTPS calls. Encapsulates all the functionality of the N/http module but does not allow the HTTP protocol.",
    "supportedIn": ["client", "server"],
    "methods": [
        {
            "name": "get",
            "description": "Sends an HTTPS GET request and returns the response.",
            "params": [
                { "name": "options", "type": "Object", "description": "Request options" },
                { "name": "options.url", "type": "string", "description": "The HTTPS URL being requested." },
                { "name": "options.headers", "type": "Object", "description": "Request headers.", "optional": true }
            ],
            "returns": "https.ClientResponse",
            "returnType": "N/https#ClientResponse"
        },
        {
            "name": "get.promise",
            "description": "Sends an HTTPS GET request asynchronously and returns the response.",
            "params": [
                { "name": "options", "type": "Object", "description": "Request options" },
                { "name": "options.url", "type": "string", "description": "The HTTPS URL being requested." },
                { "name": "options.headers", "type": "Object", "description": "Request headers.", "optional": true }
            ],
            "returns": "Promise<https.ClientResponse>"
        },
        {
            "name": "post",
            "description": "Sends an HTTPS POST request and returns the response.",
