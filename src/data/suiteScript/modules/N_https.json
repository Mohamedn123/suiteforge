                        { "name": "options", "type": "Object", "description": "Options" },
                        { "name": "options.input", "type": "string", "description": "The string to append." },
                        { "name": "options.encoding", "type": "string", "description": "The encoding of the string. Use https.Encoding enum.", "optional": true }
                    ],
                    "returns": "https.SecureString",
                    "returnType": "N/https#SecureString"
                },
                {
                    "name": "convertEncoding",
