    ],
    "objectTypes": [
        {
            "name": "Handle",
            "description": "Encapsulates a Translation Collection for a locale. Each node is either another Handle or a Translator function.",
            "methods": [],
            "properties": []
        },
        {
            "name": "Translator",
            "description": "Represents a translator function that returns translated strings. Use translation.get(options) to obtain this function. Call with options.params (array of strings) for parametrized translation strings.",
            "methods": [
                {
                    "name": "call",
                    "description": "Calls the translator function. Pass options.params (array of strings) to inject values into placeholders in the translation string.",
                    "params": [
                        { "name": "options", "type": "Object", "description": "Options", "optional": true },
                        { "name": "options.params", "type": "string[]", "description": "Parameter values for parametrized translation strings", "optional": true }
                    ],
                    "returns": "string"
                }
            ],
            "properties": []
        }
    ]
}
