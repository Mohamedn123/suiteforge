{
    "module": "N/transaction",
    "description": "Void transactions. When voided, the total and all line items are set to zero but the transaction remains in the system.",
    "supportedIn": ["client", "server"],
    "methods": [
        {
            "name": "void",
            "description": "Voids a transaction record. The type of void (direct or reversing journal) depends on the account's Using Reversing Journals preference.",
            "params": [
                { "name": "options", "type": "Object", "description": "Void options" },
                { "name": "options.type", "type": "string", "description": "The transaction type to void (transaction.Type.*)" },
                { "name": "options.id", "type": "number", "description": "The internal ID of the transaction to void" }
            ],
            "returns": "number"
        },
        {
            "name": "void.promise",
            "description": "Voids a transaction record asynchronously.",
            "params": [
                { "name": "options", "type": "Object", "description": "Void options" },
                { "name": "options.type", "type": "string", "description": "The transaction type to void (transaction.Type.*)" },
                { "name": "options.id", "type": "number", "description": "The internal ID of the transaction to void" }
            ],
            "returns": "Promise<number>"
        }
    ],
